{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020"],
    "outDir": "electron/dist",
    "rootDir": "./electron",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "typeRoots": ["./node_modules/@types"]
  },
  "include": [
    "electron/main.ts",
    "electron/preload.ts",
    "electron/electron.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src",
    "electron/dist"
  ]
}
